{
  "expo": {
    "name": "ABC Mobile",
    "slug": "ABC-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-square.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f8f6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ABCMobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-square.png",
        "backgroundColor": "#f8f8f6"
      },
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.anonymous.ABCMobile",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "extra": {
      "eas": {
        "projectId": "7bb90a7c-c171-477f-a9b2-7a568e3c433d"
      }
    }
  }
}